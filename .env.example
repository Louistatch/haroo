# Configuration de l'environnement - Plateforme Agricole Intelligente du Togo (Haroo)

# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=haroo.settings.dev

# Encryption (AES-256 pour données sensibles)
# Générer avec: python -c 'import secrets; print(secrets.token_urlsafe(32))'
ENCRYPTION_KEY=your-encryption-key-here-change-in-production

# Base de données PostgreSQL
DB_NAME=haroo_db
DB_USER=haroo_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# Celery
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# Fedapay (Paiement mobile - Togo)
# Dashboard: https://app.fedapay.com → API Keys
# pk_sandbox_* = clé publique (frontend checkout widget)
# sk_sandbox_* = clé secrète (backend API calls)
FEDAPAY_API_KEY=pk_sandbox_your-public-key
FEDAPAY_SECRET_KEY=sk_sandbox_your-secret-key
FEDAPAY_ENVIRONMENT=sandbox
FEDAPAY_WEBHOOK_SECRET=your-webhook-secret

# SMS Gateway
SMS_GATEWAY_API_KEY=your-sms-gateway-api-key
SMS_GATEWAY_SENDER_ID=HAROO

# Stockage cloud (Supabase Storage, AWS S3 ou Cloudinary)
# Choisir UN seul backend: USE_SUPABASE=True OU USE_S3=True OU USE_CLOUDINARY=True
USE_SUPABASE=True
USE_S3=False
USE_CLOUDINARY=False

# Supabase Storage Configuration (recommandé)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=documents

# AWS S3 Configuration (alternative)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=haroo-storage
AWS_S3_REGION_NAME=eu-west-1

# Cloudinary Configuration (alternative à S3)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@haroo.tg

# Sentry (Monitoring en production)
SENTRY_DSN=your-sentry-dsn

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=86400

# Taux de commission (en pourcentage)
COMMISSION_AGRONOME=10
COMMISSION_PREVENTE=5
COMMISSION_TRANSPORT=8

# Salaire minimum légal (FCFA par heure)
SALAIRE_MINIMUM_HORAIRE=500
